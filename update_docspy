    if "### 7. Runtime Permissions" not in content:
        with open(doc_path, "a", encoding="utf-8") as f:
            f.write(updates)
        print("✅ Successfully updated docs/PROJECT_STATUS.md with the final audio permission milestone!")
    else:
        print("⚠️ docs/PROJECT_STATUS.md already contains this update.")
else:
