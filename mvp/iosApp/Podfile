# CocoaPods integration for the iOS app — currently just Tor (iCepa Tor.framework), the only practical way
# to embed Tor on iOS (no clean SPM option; see ADR-009). Workflow with XcodeGen:
#   cd iosApp && xcodegen generate && pod install   # then build the .xcworkspace, not the .xcodeproj
platform :ios, '15.0'

target 'iosApp' do
  use_frameworks!
  pod 'Tor', '~> 409'
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      # Xcode "Eager Linking" generates a Tor.tbd with the same install_name as Tor.framework,
      # which makes Tor link against itself ("Can't link a dylib with itself"). Disable it.
      config.build_settings['EAGER_LINKING'] = 'NO'
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
    end
  end
end
